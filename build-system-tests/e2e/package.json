    "cypress": "^14.0.3",
    "dotenv-safe": "^8.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.1.6"
  },
  "resolutions": {
    "esbuild": "^0.25.0",
    "qs": "^6.15.0",
    "undici": "6.24.0",
    "@actions/http-client/undici": "6.24.0",
    "diff": "8.0.3",
    "serialize-javascript": "^7.0.3",
    "**/find-cypress-specs/minimatch": "3.1.4",
    "**/mocha/minimatch": "5.1.8",
